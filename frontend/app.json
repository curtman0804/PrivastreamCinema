{
  "expo": {
    "name": "Privastream Cinema",
    "slug": "privastreamcinema",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/images/icon-v4.png",
    "scheme": "privastreamcinema",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.privastream.cinema"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground-v4.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome-v4.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/images/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "package": "com.privastream.cinema",
      "allowBackup": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "enableFullScreenImage_legacy": true
        }
      ],
      "expo-font",
      "./plugins/withTVKeyEvents",
      "./plugins/withTVLauncher",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "734879b5-3cae-4195-b064-cc0c7617b7ae"
      },
      "backendUrl": "https://torrent-playback-fix.preview.emergentagent.com"
    },
    "owner": "choyt"
  }
}
